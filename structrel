            print(new_mappings)
            tree = ObjRenamer(temp_store).visit(tree)

            # Step 2: Insert definitions
            tree = ObjUpdater(mapped_ids, temp_store).visit(tree)
            tree = objGrouper(new_mappings).visit(tree)
            ast.fix_missing_locations(tree)

            return ast.unparse(tree)

        except SyntaxError as e:
