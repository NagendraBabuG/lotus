class objGrouper(ast.NodeTransformer):

    def __init__(self, new_mapings):
        self.new_mappings = new_mapings
    def visit_Assign(self, node):
        self.generic_visit(node)
        if node.targets[0].id in self.new_mappings:
            node = ast.parse(
                f"{node.targets[0].id} = {self.new_mappings[node.targets[0].id]}"
            )
            ast.fix_missing_locations(node)
            return node
        return node

    def visit_Dict(self, node):
        self.generic_visit(node)
        for k, v in self.new_mappings.items():
            if ast.unparse(node) == v:
                return ast.Name(id=k, ctx=ast.Load())
        return node

    def visit_List(self, node):
        self.generic_visit(node)
        for k, v in self.new_mappings.items():
            if ast.unparse(node) == v:
                return ast.Name(id=k, ctx=ast.Load())
        return node

class StructRef:

    def final_map(self, parent_map):
        idx = 0
        final_map = {}
        temp_store = {}

        for obj, parent in parent_map.items():
            if not isinstance(obj, (ast.Dict, ast.List)):
                continue

            if isinstance(parent, ast.Assign):
                continue

            current = parent
            while not isinstance(current, (ast.FunctionDef, ast.Module)):
                current = parent_map.get(current)
                if current is None:
                    break

            if current is None:
                continue

            key = ast.unparse(obj)

            if isinstance(current, ast.FunctionDef):
                final_map.setdefault(current.name, []).append(key)
            else:
                final_map.setdefault("module", []).append(key)

            # Store temp name
            temp_name = f"dict{idx}" if isinstance(obj, ast.Dict) else f"list{idx}"
            temp_store[key] = temp_name
            idx += 1

        return final_map, temp_store
    
    def grouper(self, old_mappings):
        new_mappings = {}
        for i in old_mappings:
            for j in old_mappings:
                if i != j and i in j:
                    new_str = j.replace(i, old_mappings[i])
                    new_mappings[old_mappings[j]] = new_str
        return new_mappings

    def get_refactored_code(self, code):
        try:
            tree = ast.parse(code)

            parent_assigner = ParentAssigner()
            parent_assigner.visit(tree)

            mapped_ids, temp_store = self.final_map(parent_assigner.parent_map)
            new_mappings = self.grouper(temp_store)
            print(mapped_ids)
