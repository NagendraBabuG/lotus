import ast


class ParentAssigner(ast.NodeVisitor):
    def __init__(self):
        self.parent_map = {}

    def visit(self, node):
        for child in ast.iter_child_nodes(node):
            self.parent_map[child] = node
            self.visit(child)


class ObjRenamer(ast.NodeTransformer):
    def __init__(self, temp_store):
        self.temp_store = temp_store

    def visit_Dict(self, node):
        self.generic_visit(node)
        key = ast.unparse(node)
        if key in self.temp_store:
            return ast.Name(id=self.temp_store[key], ctx=ast.Load())
        return node

    def visit_List(self, node):
        self.generic_visit(node)
        key = ast.unparse(node)
        if key in self.temp_store:
            return ast.Name(id=self.temp_store[key], ctx=ast.Load())
        return node


